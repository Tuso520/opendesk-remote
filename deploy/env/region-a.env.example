OPENDESK_ENV=production
OPENDESK_HTTP_ADDR=:21114
OPENDESK_PUBLIC_URL=https://remote.example.com
OPENDESK_API_URL=https://remote.example.com
OPENDESK_MYSQL_DSN=opendesk:replace-me@tcp(mysql:3306)/opendesk_remote?parseTime=true&multiStatements=true
OPENDESK_REDIS_ADDR=redis:6379
OPENDESK_REDIS_PASSWORD=replace-me
OPENDESK_STORAGE_DRIVER=local
OPENDESK_STORAGE_LOCAL_PATH=/var/lib/opendesk
OPENDESK_JWT_SECRET=replace-with-long-random-secret
OPENDESK_RELAY_GRANT_SIGNING_KEY=replace-with-long-random-signing-key
OPENDESK_RELAY_AUTH_REQUIRED=true
OPENDESK_INITIAL_ADMIN_EMAIL=admin@example.com
OPENDESK_INITIAL_ADMIN_PASSWORD=replace-with-strong-password
OPENDESK_SETUP_TOKEN=replace-with-long-random-setup-token
OPENDESK_BRAND_DEFAULT_NAME=OpenDesk Remote
OPENDESK_BRANDING_ASSET_MAX_BYTES=5242880
OPENDESK_CORS_ORIGINS=https://remote.example.com
OPENDESK_RATE_LIMIT_ENABLED=true
OPENDESK_RATE_LIMIT_REQUESTS=300
OPENDESK_RATE_LIMIT_WINDOW=1m

MYSQL_DATABASE=opendesk_remote
MYSQL_USER=opendesk
MYSQL_PASSWORD=replace-me
MYSQL_ROOT_PASSWORD=replace-me-root
OPENDESK_RELAY_PUBLIC_HOST=remote.example.com
OPENDESK_RELAY_A_ID=1
OPENDESK_RELAY_A_NAME=hbbr-relay-a
OPENDESK_RUSTDESK_SERVER_IMAGE=rustdesk/rustdesk-server:latest
