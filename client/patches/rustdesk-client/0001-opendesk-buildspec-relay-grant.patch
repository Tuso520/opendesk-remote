diff --git a/src/opendesk_relay_grant.rs b/src/opendesk_relay_grant.rs
new file mode 100644
index 0000000..368a75f
--- /dev/null
+++ b/src/opendesk_relay_grant.rs
@@ -0,0 +1,67 @@
+use hbb_common::{config::LocalConfig, log};
+use serde_derive::Deserialize;
+use serde_json::json;
+
+#[derive(Deserialize)]
+struct IssueEnvelope {
+    data: Option<IssueData>,
+}
+
+#[derive(Deserialize)]
+struct IssueData {
+    grant_token: String,
+}
+
+pub async fn issue_for_target(target_rustdesk_id: &str, fallback_token: &str) -> String {
+    if !crate::opendesk_generated::OPENDESK_RELAY_GRANT_REQUIRED {
+        return fallback_token.to_owned();
+    }
+    let api_server = crate::opendesk_generated::OPENDESK_API_SERVER.trim();
+    let relay_name = crate::opendesk_generated::OPENDESK_RELAY_NAME.trim();
+    if api_server.is_empty() || relay_name.is_empty() || target_rustdesk_id.trim().is_empty() {
+        log::warn!("OpenDesk relay grant configuration is incomplete");
+        return String::new();
+    }
+    let access_token = LocalConfig::get_option("access_token");
+    if access_token.trim().is_empty() {
+        log::warn!("OpenDesk relay grant requires an authenticated OpenDesk session");
+        return String::new();
+    }
+    let url = format!("{}/api/v1/relay-grants", api_server.trim_end_matches('/'));
+    let body = json!({
+        "target_rustdesk_id": target_rustdesk_id,
+        "allowed_relays": [relay_name],
+        "ttl_seconds": 120
+    });
+    let client = crate::hbbs_http::create_http_client_async_with_url(api_server).await;
+    let response = match client
+        .post(url)
+        .bearer_auth(access_token)
+        .json(&body)
+        .send()
+        .await
+    {
+        Ok(response) => response,
+        Err(err) => {
+            log::warn!("OpenDesk relay grant request failed: {}", err);
+            return String::new();
+        }
+    };
+    if !response.status().is_success() {
+        log::warn!(
+            "OpenDesk relay grant request rejected with status {}",
+            response.status()
+        );
+        return String::new();
+    }
+    match response.json::<IssueEnvelope>().await {
+        Ok(envelope) => envelope
+            .data
+            .map(|data| data.grant_token)
+            .unwrap_or_else(String::new),
+        Err(err) => {
+            log::warn!("OpenDesk relay grant response decode failed: {}", err);
+            String::new()
+        }
+    }
+}
