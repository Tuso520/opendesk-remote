OPENDESK_ENV=development
OPENDESK_HTTP_ADDR=:21114
OPENDESK_PUBLIC_URL=http://localhost:21114
OPENDESK_API_URL=http://localhost:21114
OPENDESK_MYSQL_DSN=
# OPENDESK_MYSQL_DSN=opendesk:opendesk@tcp(127.0.0.1:3306)/opendesk_remote?parseTime=true&multiStatements=true
OPENDESK_REDIS_ADDR=127.0.0.1:6379
OPENDESK_REDIS_PASSWORD=
OPENDESK_STORAGE_DRIVER=local
OPENDESK_STORAGE_LOCAL_PATH=./storage
OPENDESK_BRANDING_ASSET_MAX_BYTES=5242880
OPENDESK_JWT_SECRET=change-this-long-random-secret
OPENDESK_RELAY_GRANT_SIGNING_KEY=change-this-relay-grant-signing-key
OPENDESK_RELAY_AUTH_REQUIRED=true
# Leave initial admin empty to use the local-only setup endpoint on first start.
# Set both values to bootstrap an initial admin during startup.
OPENDESK_INITIAL_ADMIN_EMAIL=
OPENDESK_INITIAL_ADMIN_PASSWORD=
# Optional: allows first-run setup from a non-loopback request when no users exist.
OPENDESK_SETUP_TOKEN=
OPENDESK_BRAND_DEFAULT_NAME=OpenDesk Remote
OPENDESK_AUTH_TOKEN_TTL=15m
OPENDESK_RELAY_GRANT_TTL=2m
OPENDESK_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
OPENDESK_RATE_LIMIT_ENABLED=true
OPENDESK_RATE_LIMIT_REQUESTS=300
OPENDESK_RATE_LIMIT_WINDOW=1m
OPENDESK_BUILDER_BIN=opendesk-builder
OPENDESK_BUILDER_WORK_DIR=.run/build-worker
OPENDESK_BUILDER_SOURCE_DIR=.upstream/rustdesk-client
OPENDESK_BUILDER_DRY_RUN=true
OPENDESK_BUILDER_TIMEOUT=2h
OPENDESK_BUILDER_WINDOWS_COMMAND=
OPENDESK_BUILDER_WINDOWS_ARTIFACT_GLOB=
